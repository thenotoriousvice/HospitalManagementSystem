@{

	ViewData["Title"] = "Admin Dashboard";

}



<div class="container mt-5 p-5 bg-light rounded-4 shadow-lg">

	@* Increased overall padding to p-5 for more breathing room *@

	<div class="p-5 bg-white rounded-4 shadow-lg text-center mb-5">

		<h1 class="display-4 text-success fw-bold pb-2">

			@* Added pb-2 for slight padding under title *@

			<i class="fas fa-tachometer-alt me-3 text-info"></i>Admin Dashboard

		</h1>

		<p class="lead text-muted mb-3">Welcome, Administrator! Here you can manage the hospital system with ease.</p> @* Added mb-3 for lead text *@

		<hr class="my-4">

		<p class="mb-0 text-secondary">A comprehensive overview and quick access to essential features.</p>

	</div>



	<h2 class="text-center mb-5 text-secondary fw-bold">Quick Actions</h2> @* Increased mb-4 to mb-5 for more separation *@

	<div class="d-flex flex-wrap gap-4 justify-content-center mb-5">

		@* Increased gap-3 to gap-4 for more space between buttons *@

		<a class="btn btn-success btn-lg shadow-sm px-5 py-3 rounded-pill" asp-controller="Admin" asp-action="Index" role="button">

			<i class="fas fa-users me-2"></i> View All Patients

		</a>

		<a class="btn btn-info btn-lg shadow-sm px-5 py-3 rounded-pill" asp-controller="Admin" asp-action="Doctors" role="button">

			@* Changed to rounded-pill, increased px and py *@

			<i class="fas fa-user-md me-2"></i> Manage Doctors

		</a>

		<a class="btn btn-warning btn-lg shadow-sm px-5 py-3 rounded-pill" asp-controller="Admin" asp-action="Appointments" role="button">

			@* Changed to rounded-pill, increased px and py *@

			<i class="fas fa-calendar-alt me-2"></i> Manage Appointments

		</a>



		<!-- New Registration Dropdown -->

		<div class="dropdown">

			<button class="btn btn-primary btn-lg dropdown-toggle shadow-sm px-5 py-3 rounded-pill" type="button" id="newRegistrationDropdown" data-bs-toggle="dropdown" aria-expanded="false">

				@* Changed to rounded-pill, increased px and py *@

				<i class="fas fa-user-plus me-2"></i> New Registration

			</button>

			<ul class="dropdown-menu shadow-lg border-0 rounded-3" aria-labelledby="newRegistrationDropdown">

				<li><h6 class="dropdown-header text-primary fw-semibold">Register New User</h6></li>

				<li><hr class="dropdown-divider"></li>

				<li><a class="dropdown-item d-flex align-items-center" asp-controller="Doctor" asp-action="Register"><i class="fas fa-user-md me-2 text-info"></i>Register Doctor</a></li>

				<li><a class="dropdown-item d-flex align-items-center" asp-controller="Admin" asp-action="RegisterAdmin"><i class="fas fa-user-shield me-2 text-success"></i>Register Admin</a></li>

			</ul>

		</div>

	</div>



	<h2 class="text-center mb-4 mt-5 text-secondary fw-bold">System Overview</h2>

	<div class="row mt-4">

		<div class="col-md-6 mb-4">

			<div class="card shadow-lg h-100 rounded-4">

				@* Changed shadow-sm to shadow-lg for a bolder card lift *@

				<div class="card-header bg-primary text-white py-3 rounded-top-4">

					<h5 class="mb-0 fw-bold"><i class="fas fa-chart-bar me-2"></i>Performance At A Glance</h5>

				</div>

				<div class="card-body p-4">

					<p class="fs-5 mb-2">Total Patients: <strong class="text-primary">1,200</strong> <i class="fas fa-arrow-up text-success ms-2"></i></p>

					<p class="fs-5 mb-2">Total Doctors: <strong class="text-info">50</strong> <i class="fas fa-chart-line text-info ms-2"></i></p>

					<p class="fs-5 mb-2">Pending Appointments Today: <strong class="text-warning">15</strong> <i class="fas fa-exclamation-triangle text-warning ms-2"></i></p>

					<p class="text-muted small mt-3 border-top pt-3">Detailed analytics and reports are available in respective sections.</p>

				</div>

			</div>

		</div>

		<div class="col-md-6 mb-4">

			<div class="card shadow-lg h-100 rounded-4">

				@* Changed shadow-sm to shadow-lg for a bolder card lift *@

				<div class="card-header bg-danger text-white py-3 rounded-top-4">

					<h5 class="mb-0 fw-bold"><i class="fas fa-clipboard-list me-2"></i>Recent Activities Log</h5>

				</div>

				<div class="card-body p-4">

					<ul class="list-unstyled mb-0">

						<li class="pb-3 mb-2 border-bottom border-light">

							@* Increased pb-2 to pb-3 for more vertical spacing in list items *@

							<i class="fas fa-circle text-success small me-2"></i> Patient <strong class="text-dark">John Doe</strong> registered <span class="badge bg-light text-muted ms-2">10 mins ago</span>

						</li>

						<li class="pb-3 mb-2 border-bottom border-light">

							<i class="fas fa-circle text-info small me-2"></i> Dr. <strong class="text-dark">Sarah Smith</strong> updated profile <span class="badge bg-light text-muted ms-2">1 hour ago</span>

						</li>

						<li class="pb-3 mb-2 border-bottom border-light">

							<i class="fas fa-circle text-primary small me-2"></i> New appointment booked by <strong class="text-dark">Jane Doe</strong> <span class="badge bg-light text-muted ms-2">2 hours ago</span>

						</li>

						<li class="pb-3 mb-2 border-bottom border-light">

							<i class="fas fa-circle text-warning small me-2"></i> Payment received from <strong class="text-dark">David Lee</strong> <span class="badge bg-light text-muted ms-2">yesterday</span>

						</li>

						<li class="pb-0 mb-0">

							<i class="fas fa-circle text-secondary small me-2"></i> System backup completed <span class="badge bg-light text-muted ms-2">2 days ago</span>

						</li>

					</ul>

					<p class="text-muted small mt-3 border-top pt-3">Monitor all critical system events and user interactions.</p>

				</div>

			</div>

		</div>

	</div>

</div>



@section Scripts {

	@{

		await Html.RenderPartialAsync("_ValidationScriptsPartial");

	}

}