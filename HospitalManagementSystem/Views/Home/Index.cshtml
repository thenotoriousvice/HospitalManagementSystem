@{
	ViewData["Title"] = "Welcome to Hospital Management System";
}

<div class="container mt-5">
	<div class="text-center mb-5">
		<h1 class="display-4 fw-bold text-primary">Welcome to HMS</h1>
		<p class="lead text-muted">Please select your role to proceed.</p>
	</div>

	<div class="row justify-content-center g-4">
		<!-- Admin Card -->
		<div class="col-md-4 col-sm-6">
			<div class="card h-100 shadow-sm border-0 rounded-lg text-center p-3 hover-effect">
				<div class="card-body">
					<h5 class="card-title fs-3 mb-3 text-success">Admin</h5>
					<p class="card-text text-muted">Manage system configurations, users, and overall hospital operations.</p>
					<a asp-controller="Admin" asp-action="Login" class="btn btn-success btn-lg mt-3">Login as Admin</a>
				</div>
			</div>
		</div>

		<!-- Doctor Card -->
		<div class="col-md-4 col-sm-6">
			<div class="card h-100 shadow-sm border-0 rounded-lg text-center p-3 hover-effect">
				<div class="card-body">
					<h5 class="card-title fs-3 mb-3 text-info">Doctor</h5>
					<p class="card-text text-muted">Access patient records, manage appointments, and view medical histories.</p>
					<a asp-controller="Doctor" asp-action="Login" class="btn btn-info btn-lg mt-3">Login as Doctor</a>
				</div>
			</div>
		</div>

		<!-- Patient Card -->
		<div class="col-md-4 col-sm-6">
			<div class="card h-100 shadow-sm border-0 rounded-lg text-center p-3 hover-effect">
				<div class="card-body">
					<h5 class="card-title fs-3 mb-3 text-warning">Patient</h5>
					<p class="card-text text-muted">View your profile, book appointments, and manage your payments.</p>
					<a asp-controller="Patient" asp-action="Login" class="btn btn-warning btn-lg mt-3">Login as Patient</a>
					<a asp-controller="Patient" asp-action="Register" class="btn btn-outline-warning btn-sm mt-2 d-block mx-auto" style="max-width: 180px;">New Patient? Register</a>
				</div>
			</div>
		</div>
	</div>
</div>

<style>
	/* Custom hover effect for cards */
	.hover-effect {
		transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
	}

		.hover-effect:hover {
			transform: translateY(-5px);
			box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
		}
</style>

@section Scripts {
	<!-- If you want smooth scroll for future anchors on this page -->
	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
}
