@model HospitalManagementSystem.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Patient Login";
    // Get the return URL if it was passed, so we can redirect correctly after login
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<!-- Link to Bootstrap CSS (assuming it's already in _Layout.cshtml, but including for completeness) -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" xintegrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">Patient Login</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Login" asp-route-returnurl="@returnUrl" method="post">
                        @* Display all validation errors at the top *@
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="ContactNumberOrEmail" class="form-label"></label>
                            <input asp-for="ContactNumberOrEmail" class="form-control" placeholder="Enter Contact Number or Email" />
                            <span asp-validation-for="ContactNumberOrEmail" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Enter Password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" type="checkbox" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Log in</button>
                        </div>

                        <div class="text-center mt-3">
                            <p>Not registered yet? <a asp-action="Register">Register as a Patient</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Link to Bootstrap JS (assuming it's already in _Layout.cshtml, but including for completeness) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" xintegrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
