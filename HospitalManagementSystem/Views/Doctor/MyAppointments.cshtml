@using HospitalManagementSystem.Repository.Models
@model IEnumerable<HospitalManagementSystem.Repository.Models.Appointment>

@{
    ViewData["Title"] = "My Scheduled Appointments";
}

<h1>My Scheduled Appointments</h1>

@if (TempData["Message"] != null)
{
    <div class="alert alert-info">@TempData["Message"]</div>
}

@if (!Model.Any())
{
    <p>No appointments found for your profile.</p>
}
else
{
    <table class="table table-striped table-bordered mt-3">
        <thead class="thead-dark">
            <tr>
                <th>Patient Name</th>
                <th>Patient Email</th>
                <th>Patient Phone</th>
                <th>Appointment Date</th>
                <th>Time</th>
                <th>Department</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Patient.Name)</td>
                    <td>@Html.DisplayFor(modelItem => item.Patient.Email)</td>
                    <td>@Html.DisplayFor(modelItem => item.Patient.PhoneNumber)</td>
                    <td>@Html.DisplayFor(modelItem => item.AppointmentDate)</td>
                    <td>
                        @(item.AppointmentTime.HasValue
                                ? new DateTime().Add(item.AppointmentTime.Value).ToString("hh:mm tt")
                                : "Not Set")
                    </td>
                    <td>@(item.Department?.Name ?? "N/A")</td>
                    <td>@Html.DisplayFor(modelItem => item.Reason)</td>
                    <td>@Html.DisplayFor(modelItem => item.Status)</td>
                    <td>
                        @* Logic for Doctors to Approve/Reject/Cancel appointments from this view *@
                        @if (item.Status == AppointmentStatus.Pending)
                        {
                            <form asp-controller="Doctor" asp-action="Approve" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <div class="d-flex align-items-center mb-2"> @* Added mb-2 for spacing *@
                                    <input type="time" name="approvedTimeString" class="form-control me-2" style="width: auto;" required />
                                    <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('Are you sure you want to approve this appointment and set this time?');">Approve</button>
                                </div>
                            </form>
                            <form asp-controller="Doctor" asp-action="Reject" method="post" class="d-inline me-2">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to reject this appointment?');">Reject</button>
                            </form>
                        }
                        @* Doctors can also cancel appointments from this view, regardless of status (unless completed). *@
                        @if (item.Status == AppointmentStatus.Pending || item.Status == AppointmentStatus.Approved)
                        {
                            <form asp-controller="Doctor" asp-action="Cancel" method="post" class="d-inline mt-2"> @* Added mt-2 for spacing *@
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-warning btn-sm" onclick="return confirm('Are you sure you want to cancel this appointment?');">Cancel</button>
                            </form>
                        }
                        else if (item.Status == AppointmentStatus.Cancelled || item.Status == AppointmentStatus.Rejected || item.Status == AppointmentStatus.Approved)
                        {
                            <span>-</span> @* Display a dash or current status for completed/cancelled/rejected appointments *@
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}